generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String?   @unique
  createdAt              DateTime  @default(now())
  image                  String?
  name                   String?
  updatedAt              DateTime  @updatedAt
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  subscriptionStatus     String?
  emailVerified          DateTime?
  stripeCurrentPeriodEnd DateTime?
  proUntil               DateTime? // gifted pro access — null means not gifted
  preferredCurrency      String    @default("USD") // "USD" | "AUD" | "CAD" | "GBP" | "EUR"
  accounts               Account[]
  alerts                 Alert[]
  holdings               Holding[]
  predictions            Prediction[]
  sessions               Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Alert {
  id              String         @id @default(cuid())
  metal           String
  direction       String
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  userId          String
  price           Float?
  updatedAt       DateTime       @updatedAt
  lastTriggeredAt DateTime?
  percentValue    Float?
  type            String         @default("price")
  currency        String         @default("USD") // currency the price threshold is stored in
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggers        AlertTrigger[]

  @@index([userId])
  @@index([active])
}

model AlertTrigger {
  id          String   @id @default(cuid())
  alertId     String
  price       Float
  triggeredAt DateTime @default(now())
  alert       Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
}

model Price {
  id        String   @id @default(cuid())
  metal     String
  price     Float
  timestamp DateTime

  @@unique([metal, timestamp], name: "metal_timestamp")
  @@index([metal, timestamp(sort: Desc)])
}

model Prediction {
  id          String   @id @default(cuid())
  userId      String
  metal       String   @default("gold")
  direction   String   // "up" | "down"
  date        String   // YYYY-MM-DD UTC — the day the prediction was made
  basePrice   Float    // spot price when prediction was made
  resultPrice Float?   // spot price the following day
  correct     Boolean? // null until evaluated by cron
  voided      Boolean  @default(false) // true if price was flat — excluded from stats
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, metal])
  @@index([userId])
}

model Holding {
  id            String   @id @default(cuid())
  userId        String
  metal         String
  ounces        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  purchaseDate  DateTime
  purchasePrice Float
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailSubscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  createdAt        DateTime @default(now())
  unsubscribeToken String   @unique @default(cuid())
  active           Boolean  @default(true)
  source           String   @default("unknown")
}

// Outbound dealer click tracking. Every click on a /compare row (and later,
// on dealer CTAs in alert emails / digest) routes through /api/track/click,
// which logs a DealerClick row and 302-redirects to the (affiliate-wrapped)
// dealer URL. The `subId` we mint here is also passed through to the
// affiliate network's sub-ID slot (Awin clickref, FlexOffers fos), so when
// commission reports come back we can join them against this table to see
// which coin × dealer × source actually converts.
//
// We intentionally store an IP hash rather than the raw IP — analytics
// signal (unique-click counting, bot detection) without retaining PII any
// longer than necessary.
model DealerClick {
  id        String   @id @default(cuid())
  coinId    String   // matches CompareCoin["id"] in lib/compare/coins.ts
  dealerId  String   // matches Dealer["id"] in lib/compare/dealers.ts
  userId    String?  // null for anonymous visitors
  subId     String   @unique
  source    String   @default("compare") // "compare" | "alert-email" | "digest" | "faq" | etc
  userAgent String?
  ipHash    String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([coinId, dealerId, createdAt])
  @@index([dealerId, createdAt])
  @@index([source, createdAt])
  @@index([userId])
}

{
  "name": "precious-metals-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "backfill": "ts-node scripts/backfill-prices.ts",
    "timeseries": "ts-node scripts/backfill-timeseries.ts",
    "screenshot": "node scripts/screenshot.js",
    "screenshot:local": "SCREENSHOT_URL=http://localhost:3000 node scripts/screenshot.js",
    "check-data": "ts-node scripts/check-gold-data.ts",
    "dedup": "ts-node scripts/dedup-prices.ts",
    "verify-slugs": "TS_NODE_PROJECT=scripts/tsconfig.json ts-node scripts/verify-compare-slugs.ts",
    "verify-slugs:open": "TS_NODE_PROJECT=scripts/tsconfig.json ts-node scripts/verify-compare-slugs.ts -- --open"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.3.1",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "puppeteer": "^24.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.15.4",
    "resend": "^3.5.0",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
